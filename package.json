{
  "name": "mdrun",
  "version": "0.1.0",
  "description": "Terminal markdown viewer with executable code fences",
  "type": "module",
  "bin": {
    "mdrun": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun build src/cli.ts --outfile dist/cli.js --target bun --external '*' --sourcemap --watch",
    "build": "bun build src/cli.ts --outfile dist/cli.js --target bun --external '*' --sourcemap",
    "start": "bun dist/cli.js",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@opentui/core": "^0.4.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0"
  },
  "packageManager": "bun@1.x"
}
