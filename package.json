{
  "name": "mdrun",
  "version": "0.1.0",
  "description": "Terminal markdown viewer with executable code fences",
  "type": "module",
  "bin": {
    "mdrun": "./dist/cli.js"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node --enable-source-maps dist/cli.js"
  },
  "dependencies": {
    "@opentui/core": "^0.4.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
